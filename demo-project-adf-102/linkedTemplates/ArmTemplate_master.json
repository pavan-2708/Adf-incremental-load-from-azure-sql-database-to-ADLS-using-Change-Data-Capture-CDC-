{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "demo-project-adf-102"
		},
		"ls_adls_sink_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_sink'"
		},
		"ls_sql_db_src_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_db_src'"
		},
		"ls_adls_sink_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://demoprojectsa101.dfs.core.windows.net/"
		},
		"ls_sql_db_src_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "demo-sql-server-101.database.windows.net"
		},
		"ls_sql_db_src_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "demo-db"
		},
		"ls_sql_db_src_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pavan"
		},
		"trigger1_properties_pipeline_parameters_triggerStartTime": {
			"type": "string",
			"defaultValue": "@formatDateTime(trigger().outputs.windowStartTime,'yyyy-MM-dd HH:mm:ss.fff')"
		},
		"trigger1_properties_pipeline_parameters_triggerEndTime": {
			"type": "string",
			"defaultValue": "@formatDateTime(trigger().outputs.windowEndTime,'yyyy-MM-dd HH:mm:ss.fff')"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "demo-project-adf-102_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_sink_accountKey": {
						"value": "[parameters('ls_adls_sink_accountKey')]"
					},
					"ls_sql_db_src_password": {
						"value": "[parameters('ls_sql_db_src_password')]"
					},
					"ls_adls_sink_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_sink_properties_typeProperties_url')]"
					},
					"ls_sql_db_src_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_db_src_properties_typeProperties_server')]"
					},
					"ls_sql_db_src_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_db_src_properties_typeProperties_database')]"
					},
					"ls_sql_db_src_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_db_src_properties_typeProperties_userName')]"
					},
					"trigger1_properties_pipeline_parameters_triggerStartTime": {
						"value": "[parameters('trigger1_properties_pipeline_parameters_triggerStartTime')]"
					},
					"trigger1_properties_pipeline_parameters_triggerEndTime": {
						"value": "[parameters('trigger1_properties_pipeline_parameters_triggerEndTime')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}